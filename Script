  // ── API calls ─────────────────────────────────────────────────────────────────

  function apiGet(url) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'GET',
        url,
        timeout: 12000,
        onload: (r) => {
          try { resolve(JSON.parse(r.responseText)); }
          catch(e) { reject(new Error('JSON parse failed')); }
        },
        onerror: () => reject(new Error('Network error')),
        ontimeout: () => reject(new Error('Timeout')),
      });
    });
  }

  // Fetch item metadata + v1 market_value (used for type/name, and as fallback price)
  async function fetchTornItemsV1(apiKey) {
    const data = await apiGet(
      `https://api.torn.com/torn/?selections=items&key=${apiKey}&comment=TEEM`
    );
    if (data.error) throw new Error(`Torn API error ${data.error.code}: ${data.error.error}`);
    return data.items ?? {};
  }

  // Fetch live lowest-listing prices from v2 item market
  // Returns { itemId: lowestListingPrice } or null if v2 unsupported
  async function fetchV2LivePrices(apiKey) {
    try {
      const data = await apiGet(
        `https://api.torn.com/v2/market/itemmarket?key=${apiKey}&comment=TEEM`
      );
      if (data.error) {
        // Error code 9 = API disabled, 13 = not available = v2 not supported for this key
        console.warn('[TMIT] V2 market error:', data.error.code, data.error.error);
        return null;
      }
      // v2 returns { itemmarket: { items: [ { id, lowest_price, ... } ] } }
      const items = data?.itemmarket?.items ?? data?.items ?? [];
      if (!items.length) return null;
      const prices = {};
      for (const item of items) {
        if (item.id && item.lowest_price) {
          prices[item.id] = item.lowest_price;
        }
      }
      return Object.keys(prices).length > 0 ? prices : null;
    } catch(e) {
      console.warn('[TMIT] V2 fetch failed:', e.message);
      return null;
    }
  }

  // Smart fetch: tries v2 for live prices, falls back to v1 market_value
  // Returns { items: {id: itemObj}, livePrices: {id: price}, usingV2: bool }
  async function fetchTornItems(apiKey) {
    // Always fetch v1 for item metadata (name, type, market_value fallback)
    const v1Items = await fetchTornItemsV1(apiKey);

    // Try v2 if not previously determined to be unsupported
    let livePrices = null;
    let usingV2 = false;

    if (settings.useV2 !== false) {
      livePrices = await fetchV2LivePrices(apiKey);
      if (livePrices !== null) {
        usingV2 = true;
        if (settings.useV2 !== true) {
          settings.useV2 = true;
          saveSettings();
          console.info('[TMIT] V2 live prices enabled ✓');
        }
      } else if (settings.useV2 === null) {
        // First attempt failed — mark as unsupported so we stop trying
        settings.useV2 = false;
        saveSettings();
        console.info('[TMIT] V2 unavailable, using v1 market_value');
      }
    }

    return { items: v1Items, livePrices, usingV2 };
  }

  async function fetchYataPrices() {
    try {
      const data = await apiGet('https://yata.life/api/v1/bazaar/abroad/?format=json');
      // yata returns item price data — normalize to { id: price }
      const result = {};
      for (const [idStr, itemData] of Object.entries(data ?? {})) {
        const price = itemData?.market_value ?? itemData?.price ?? null;
        if (price) result[parseInt(idStr)] = price;
      }
      return result;
    } catch(e) {
      console.warn('[TMIT] YATA fetch failed:', e.message);
      return {};
    }
  }

  // ── Analysis engine ───────────────────────────────────────────────────────────

  function getTimeframeMs(label) {
    return TIMEFRAMES.find(t => t.label === label)?.ms ?? TIMEFRAMES[2].ms;
  }

  function analyzeItem(itemId, currentPrice, yataPrice, timeframeMs) {
    const history = priceHistory[itemId] ?? [];
    if (history.length < 2) return null;

    const now = Date.now();
    const cutoff = now - timeframeMs;
    const windowData = history.filter(h => h.ts >= cutoff);
    if (windowData.length < 2) return null;

    const oldest = windowData[0];
    const newest = windowData[windowData.length - 1];

    // Cross-reference torn vs yata
    const effectivePrice = (currentPrice && yataPrice)
      ? Math.round((currentPrice * 0.6) + (yataPrice * 0.4))
      : (currentPrice || yataPrice || 0);

    const oldestPrice = oldest.price || oldest.yataPrice || 0;
    if (!oldestPrice || !effectivePrice) return null;

    const changePct = ((effectivePrice - oldestPrice) / oldestPrice) * 100;

    // Volatility — std dev of price changes in window
    const prices = windowData.map(h => h.price || h.yataPrice || 0).filter(Boolean);
    const mean = prices.reduce((a, b) => a + b, 0) / prices.length;
    const variance = prices.reduce((a, b) => a + Math.pow(b - mean, 2), 0) / prices.length;
    const volatility = Math.sqrt(variance) / mean * 100;

    // Trend — simple linear regression slope
    const n = windowData.length;
    const xs = windowData.map((_, i) => i);
    const ys = windowData.map(h => h.price || h.yataPrice || 0);
    const sumX = xs.reduce((a,b) => a+b, 0);
    const sumY = ys.reduce((a,b) => a+b, 0);
    const sumXY = xs.reduce((a,b,i) => a + b*ys[i], 0);
    const sumX2 = xs.reduce((a,b) => a + b*b, 0);
    const slope = n > 1 ? (n*sumXY - sumX*sumY) / (n*sumX2 - sumX*sumX) : 0;
    const trendPct = mean > 0 ? (slope / mean) * 100 : 0;

    // Signal logic
    let signal = 'WATCH';
    let confidence = 1;

    if (changePct > 5 && trendPct > 0) {
      signal = 'BUY'; confidence = Math.min(3, Math.floor(changePct / 5));
    } else if (changePct < -8 && trendPct < 0) {
      signal = 'SELL'; confidence = Math.min(3, Math.floor(Math.abs(changePct) / 8));
    } else if (changePct > 2) {
      signal = 'HOLD'; confidence = 2;
    } else if (Math.abs(changePct) < 1 && volatility > 8) {
      signal = 'WATCH'; confidence = 2;
    }

    // Big spike detection
    const isSpike = Math.abs(changePct) > 15;
    const isBigSpike = Math.abs(changePct) > 30;

    // Data source confidence
    const dataSources = (currentPrice ? 1 : 0) + (yataPrice ? 1 : 0);

    return {
      itemId: parseInt(itemId),
      name: itemMeta[itemId]?.name ?? `Item #${itemId}`,
      type: itemMeta[itemId]?.type ?? 'Unknown',
      currentPrice: effectivePrice,
      tornPrice: currentPrice,
      yataPrice,
      changePct: Math.round(changePct * 10) / 10,
      volatility: Math.round(volatility * 10) / 10,
      trendPct: Math.round(trendPct * 100) / 100,
      signal,
      confidence,
      isSpike,
      isBigSpike,
      dataPoints: windowData.length,
      dataSources,
    };
  }

  function runAnalysis() {
    const tfMs = getTimeframeMs(settings.selectedTimeframe);
    const results = [];

    for (const [idStr, prices] of Object.entries(priceHistory)) {
      if (!prices.length) continue;
      const latest = prices[prices.length - 1];
      const result = analyzeItem(idStr, latest.price, latest.yataPrice, tfMs);
      if (result) results.push(result);
    }

    // Sort
    results.sort((a, b) => {
      switch (settings.sortBy) {
        case 'profit_pct': return Math.abs(b.changePct) - Math.abs(a.changePct);
        case 'price':      return b.currentPrice - a.currentPrice;
        case 'volatility': return b.volatility - a.volatility;
        case 'signal':     return ['BUY','HOLD','WATCH','SELL'].indexOf(a.signal) - ['BUY','HOLD','WATCH','SELL'].indexOf(b.signal);
        default:           return Math.abs(b.changePct) - Math.abs(a.changePct);
      }
    });

    analysisCache = results;

    // Alert if any big spikes
    const bigSpikes = results.filter(r => r.isBigSpike);
    if (bigSpikes.length > 0 && !alertActive) {
      alertActive = true;
      document.getElementById('tmit-fab')?.classList.add('tmit-alert');
    } else if (bigSpikes.length === 0 && alertActive) {
      alertActive = false;
      document.getElementById('tmit-fab')?.classList.remove('tmit-alert');
    }

    return results;
  }

  // ── Poll ──────────────────────────────────────────────────────────────────────

  async function poll(force = false) {
    if (!settings.apiKey) return;

    try {
      setStatus('loading', '…');

      const [tornResult, yataPrices] = await Promise.all([
        fetchTornItems(settings.apiKey),
        fetchYataPrices(),
      ]);

      const { items: tornItems, livePrices, usingV2 } = tornResult;
      lastYataPrices = yataPrices;
      // Resolve travel item IDs from real API names
      resolveTravelItemIds(tornItems);

      // Also fetch YATA travel stock for travel tab
      try {
        const travelStock = await apiGet('https://yata.life/api/v1/travel/export/?format=json');
        if (travelStock && !travelStock.error) {
          const result = {};
          for (const [countryKey, countryData] of Object.entries(travelStock?.countries ?? {})) {
            const code = countryKey.toLowerCase().slice(0, 3);
            result[code] = {};
            for (const [itemIdStr, itemData] of Object.entries(countryData?.items ?? {})) {
              const stockPct = itemData?.stock ?? itemData?.quantity ?? 100;
              result[code][parseInt(itemIdStr)] = Math.min(stockPct / 100, 1.0);
            }
          }
          if (Object.keys(result).length > 0) yataStockCache = result;
        }
      } catch(e) { /* silent fail */ }

      // Update item metadata and price history
      const seenTypes = new Set(['All']);
      for (const [idStr, item] of Object.entries(tornItems)) {
        const id = parseInt(idStr);
        // Cache metadata — store the EXACT type string Torn returns
        const rawType = item.type ?? 'Unknown';
        itemMeta[id] = { name: item.name, type: rawType };
        if (rawType) seenTypes.add(rawType);
        // Price priority: v2 live listing > yata > v1 market_value
        const livePrice  = livePrices?.[id] ?? 0;
        const yataPrice  = yataPrices[id] ?? 0;
        const v1Price    = item.market_value ?? 0;
        // Use live price as primary torn price if available, else v1
        const tornPrice  = livePrice || v1Price;
        if (tornPrice > 0 || yataPrice > 0) {
          appendHistory(id, tornPrice, yataPrice);
        }
      }
      // Rebuild categories from real API type strings and update the dropdown
      CATEGORIES = ['All', ...Array.from(seenTypes).filter(t => t !== 'All').sort()];
      const catSelect = document.getElementById('tmit-cat-select');
      if (catSelect) {
        const currentVal = catSelect.value;
        catSelect.innerHTML = CATEGORIES.map(c =>
          `<option value="${c}"${c === currentVal ? ' selected' : ''}>${c}</option>`
        ).join('');
      }

      store('itemMeta', itemMeta);
      saveHistory();

      const src = usingV2 ? '⚡ Live' : '~ Avg';
      setStatus('ok', `${src} · ${new Date().toLocaleTimeString()}`);

      // Fetch BB balance from user inventory if we can
      try {
        const inv = await apiGet(
          `https://api.torn.com/user/?selections=inventory&key=${settings.apiKey}&comment=TEEM`
        );
        if (inv?.inventory) {
          // BB are item ID 529 (Bunker Bucks) in inventory
          const bbItem = Object.values(inv.inventory).find(i => i.name === 'Bunker Buck' || i.ID === 529);
          if (bbItem) userBBBalance = bbItem.quantity ?? 0;
        }
      } catch(e) { /* BB fetch optional, silent fail */ }

      recomputeTravel();
      renderList();
      // Re-render travel tab if active
      if (settings.activeTab === 'travel') renderTravelTab();
    } catch(e) {
      console.error('[TMIT] Poll failed:', e);
      setStatus('err', e.message.slice(0, 40));
    }
  }

  function startPolling() {
    if (pollingTimer) clearInterval(pollingTimer);
    poll(true);
    pollingTimer = setInterval(() => poll(), POLL_MS);
  }

