  function buildOnboarding(iconDataUrl) {
    const el = document.createElement('div');
    el.id = 'tmit-onboard';
    el.innerHTML = `
      <div class="tmit-onboard-card">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
